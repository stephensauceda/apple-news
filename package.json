{
  "name": "@stephensauceda/apple-news",
  "version": "0.1.0",
  "description": "Modern Apple News API client for Node.js",
  "author": "Stephen Sauceda",
  "type": "module",
  "main": "./dist/index.js",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./helpers": "./dist/helpers.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stephensauceda/apple-news.git"
  },
  "bugs": {
    "url": "https://github.com/stephensauceda/apple-news/issues"
  },
  "homepage": "https://github.com/stephensauceda/apple-news#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/stephensauceda"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./local/scripts/build.mjs",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "apple-news",
    "apple-news-api",
    "news",
    "api-client",
    "nodejs",
    "publishing"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.24.0",
    "globals": "^15.15.0",
    "esbuild": "^0.25.2",
    "prettier": "^3.5.3",
    "vitest": "^3.1.1"
  }
}
